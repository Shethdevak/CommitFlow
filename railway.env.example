# Copy these into Railway → Variables (API service).
# Keep using your existing Render Postgres URL so accounts/data stay the same.

# --- core ---
API_SECRET_KEY=
API_DATABASE_URL=           # same External Database URL from Render Postgres
API_USER_DATA_DIR=data/users
API_CORS_ORIGINS=https://commit-flow-two.vercel.app,http://localhost:5173
API_FRONTEND_URL=https://commit-flow-two.vercel.app
API_PUBLIC_URL=             # set AFTER first deploy, e.g. https://commitflow-api-production.up.railway.app
JWT_EXPIRE_HOURS=12
JWT_REMEMBER_HOURS=720

# --- Gmail App Password (works on Railway; blocked on Render) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=commitflow111@gmail.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=CommitFlow <commitflow111@gmail.com>
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# --- optional GitHub OAuth ---
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
