# ==============================================================================
# AI-Powered Redmine Worklog Automation Configuration
# Rename this file to .env and fill in your credentials.
# ==============================================================================

# Git Integrations
GITHUB_TOKEN=your_github_personal_access_token
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_API_URL=https://gitlab.com  # Set to self-hosted URL if not using GitLab Cloud
AUTHOR_NAME=  # Optional: auto-detected from GitHub/GitLab token if left empty

# Redmine Integration
REDMINE_URL=https://redmine.yourcompany.com
REDMINE_API_KEY=your_redmine_api_key

# Database and Mappings
DB_PATH=commitflow.db
MAPPINGS_PATH=configs/repo_mappings.yaml

# Local/timezone configuration
TIMEZONE=UTC  # e.g., America/New_York, Asia/Kolkata, UTC

# Daily worklog goals (to-dos + time entries)
DAILY_HOUR_GOAL=8
MIN_TODOS=3
# Fuzzy match score (0-100) when mapping repo name → Redmine project
PROJECT_MATCH_THRESHOLD=70

# AI Integration Configuration
# Supported providers: openai, gemini, anthropic, openrouter, ollama, groq
AI_PROVIDER=groq  # Recommended: groq (fast + free tier)
AI_CONFIDENCE_THRESHOLD=80
DEFAULT_FEATURE=General Development

# AI Provider API Keys & URLs
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o  # Optional: defaults to gpt-4o

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash  # Optional: defaults to gemini-1.5-flash

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620  # Optional

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct  # Optional

OLLAMA_API_URL=http://localhost:11434  # Default local URL
OLLAMA_MODEL=llama3  # Optional: defaults to llama3

# Groq (fast inference, free tier available — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile  # Optional: defaults to llama-3.3-70b-versatile

# ==============================================================================
# Web API (optional — only needed for the multi-user frontend)
# Does NOT replace your personal CLI .env values above.
# ==============================================================================
API_SECRET_KEY=change-me-to-a-long-random-string
# Optional dedicated Fernet key; if empty, derived from API_SECRET_KEY
API_FERNET_KEY=
API_DATABASE_URL=sqlite:///./data/commitflow_web.db
API_USER_DATA_DIR=data/users
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
JWT_EXPIRE_HOURS=72

# Optional: Login with GitHub (OAuth App — separate from GITHUB_TOKEN)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

