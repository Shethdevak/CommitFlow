# =============================================================================
# CommitFlow — Vercel BACKEND env TEMPLATE (no secrets)
# Copy to vercel.env, fill secrets, paste into Vercel Raw Editor.
# Root Directory: . (repo root, NOT web/)
# =============================================================================

API_SECRET_KEY=generate-a-long-random-hex-string
API_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME
API_USER_DATA_DIR=/tmp/commitflow-data/users
JWT_EXPIRE_HOURS=12
JWT_REMEMBER_HOURS=720

API_CORS_ORIGINS=https://commit-flow-two.vercel.app,http://localhost:5173,http://127.0.0.1:5173
API_FRONTEND_URL=https://commit-flow-two.vercel.app
API_PUBLIC_URL=https://commit-flow-xf22.vercel.app

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=CommitFlow <your@gmail.com>
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
