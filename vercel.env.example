# Vercel backend project (commit-flow-xf22) — Environment Variables
# Root Directory: repository root (NOT web/)

API_SECRET_KEY=
API_DATABASE_URL=
API_USER_DATA_DIR=/tmp/commitflow-data/users
API_CORS_ORIGINS=https://commit-flow-two.vercel.app,http://localhost:5173
API_FRONTEND_URL=https://commit-flow-two.vercel.app
API_PUBLIC_URL=https://commit-flow-xf22.vercel.app
JWT_EXPIRE_HOURS=12
JWT_REMEMBER_HOURS=720

# Gmail SMTP usually FAILS on Vercel (outbound SMTP blocked).
# Prefer EMAIL_PROVIDER=bridge to a VPS mail bridge, or Resend.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=CommitFlow <your@gmail.com>
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
